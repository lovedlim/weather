# 단기예보 VilageFcstInfoService_2.0 — 포털에서 발급한 일반 인증키(Decoding 권장).
KMA_SERVICE_KEY=

# 중기예보 MidFcstInfoService — 포털에서 중기예보 API를 따로 활용신청한 경우의 인증키.
# 비우면 KMA_SERVICE_KEY로 중기도 호출합니다.
KMA_MID_SERVICE_KEY=

PORT=3000

# 단기예보 격자 (서울 시청 부근 기본값). 다른 지역은 lat/lon 쿼리로 자동 변환 가능.
DEFAULT_NX=61
DEFAULT_NY=125

# 중기예보(기온·육상) 예보구역코드. 가이드의 regId 표 참고 (기본: 서울·인천·경기 등 11B00000).
# 날짜가 하루 어긋나면 MID_DAY_INDEX_OFFSET=-1 등으로 조정.
DEFAULT_MID_REG_ID=11B00000
# MID_DAY_INDEX_OFFSET=0
